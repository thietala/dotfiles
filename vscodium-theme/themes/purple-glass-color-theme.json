  "tokenColors": [
    { "scope": "comment",
      "settings": { "foreground": "#4a3868", "fontStyle": "italic" } },
    { "scope": "comment.line.double-slash",
      "settings": { "foreground": "#4a3868", "fontStyle": "italic" } },

    { "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#6bc4a0" } },
    { "scope": "string.template",
      "settings": { "foreground": "#88d4b8" } },
    { "scope": "string.regexp",
      "settings": { "foreground": "#a87cc4" } },

    { "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#c4b06b" } },
    { "scope": "constant.character.escape",
      "settings": { "foreground": "#c499d8" } },

    { "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#9b7bc4", "fontStyle": "bold" } },
    { "scope": ["keyword.operator"],
      "settings": { "foreground": "#8878a8", "fontStyle": "" } },
    { "scope": "storage.type",
      "settings": { "foreground": "#9b7bc4", "fontStyle": "bold" } },
    { "scope": "storage.modifier",
      "settings": { "foreground": "#8a6aae", "fontStyle": "italic" } },

    { "scope": ["entity.name.function", "meta.function-call.generic"],
      "settings": { "foreground": "#b89edd" } },
    { "scope": "entity.name.type",
      "settings": { "foreground": "#a87cc4" } },
    { "scope": "entity.name.class",
      "settings": { "foreground": "#a87cc4", "fontStyle": "bold" } },
    { "scope": "entity.name.namespace",
      "settings": { "foreground": "#8a6aae" } },
    { "scope": "entity.name.tag",
      "settings": { "foreground": "#9b7bc4" } },
    { "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#b89edd" } },
    { "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#a87cc4", "fontStyle": "italic" } },

    { "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#e8e0f0" } },
    { "scope": "variable.parameter",
      "settings": { "foreground": "#c4b8d8", "fontStyle": "italic" } },
    { "scope": ["variable.language", "variable.other.this", "variable.other.self"],
      "settings": { "foreground": "#9b7bc4", "fontStyle": "italic" } },

    { "scope": "support.function",
      "settings": { "foreground": "#88c0d8" } },
    { "scope": "support.type",
      "settings": { "foreground": "#a87cc4" } },
    { "scope": "support.class",
      "settings": { "foreground": "#a87cc4" } },
    { "scope": "support.constant",
      "settings": { "foreground": "#c4b06b" } },

    { "scope": "meta.decorator",
      "settings": { "foreground": "#c499d8" } },
    { "scope": "meta.object-literal.key",
      "settings": { "foreground": "#b89edd" } },
    { "scope": "meta.tag",
      "settings": { "foreground": "#e8e0f0" } },

    { "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#8878a8" } },
    { "scope": "punctuation.separator",
      "settings": { "foreground": "#8878a8" } },
    { "scope": "punctuation.terminator",
      "settings": { "foreground": "#8878a8" } },

    { "scope": "markup.heading",
      "settings": { "foreground": "#9b7bc4", "fontStyle": "bold" } },
    { "scope": "markup.bold",
      "settings": { "foreground": "#e8e0f0", "fontStyle": "bold" } },
    { "scope": "markup.italic",
      "settings": { "foreground": "#c4b8d8", "fontStyle": "italic" } },
    { "scope": "markup.underline.link",
      "settings": { "foreground": "#6ba8c4" } },
    { "scope": "markup.quote",
      "settings": { "foreground": "#4a3868", "fontStyle": "italic" } },
    { "scope": "markup.inline.raw",
      "settings": { "foreground": "#6bc4a0" } },
    { "scope": "markup.inserted",
      "settings": { "foreground": "#6bc4a0" } },
    { "scope": "markup.deleted",
      "settings": { "foreground": "#e06b6b" } },
    { "scope": "markup.changed",
      "settings": { "foreground": "#c4b06b" } },

    { "scope": "invalid",
      "settings": { "foreground": "#e06b6b", "fontStyle": "underline" } },
    { "scope": "invalid.deprecated",
      "settings": { "foreground": "#c4b06b", "fontStyle": "underline italic" } }
  ]
}
